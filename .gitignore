# Template for Python/R .gitignore (github.com/github/gitignore)

# ── Python (byte-compiled, packaging, distribution) ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ── Python testing / coverage ──
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ── Translations ──
*.mo
*.pot

# ── Python environments & package managers ──
.venv
venv/
env/
ENV/
env.bak/
venv.bak/
.pdm.toml
.pdm-python
.pdm-build/
__pypackages__/

# ── Python type checkers / linters ──
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.ruff_cache/
.pypirc

# ── R / RStudio ──
.Rhistory
.Rapp.history
.RData
.RDataTmp*
.Ruserdata
.Rproj.user/
.Rprofile
!/.Rprofile  # keep project .Rprofile if present
.Renviron
.httr-oauth
Rplots.pdf
Rtmp*/
*-Ex.R
/*.tar.gz
/*.Rcheck/
vignettes/*.html
vignettes/*.pdf
*_cache/
/cache/
*.utf8.md
*.knit.md

# ── Jupyter / IPython ──
.ipynb_checkpoints
profile_default/
ipython_config.py

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ── Quarto / LaTeX ──
/.quarto/
*.aux
*.bbl
*.bcf
*.blg
*.fls
*.fdb_latexmk
*.out
*.synctex.gz
*.run.xml
*.toc
*.lof
*.lot

# ── Editors / IDEs ──
.vscode/
*.code-workspace
.idea/
*.swp
*.swo
.qodo

# ── OS files ──
.DS_Store
**/.DS_Store
Thumbs.db

# ── Environment / secrets ──
.env
.env.*
!.env.example
!.env.*.example

# ── Logs ──
*.log

# ── Documentation builds ──
docs/_build/
/site

# ── Temporary files ──
temp/
tmp/

# ── Hidden files ──
.hidden/

# ── UV lockfile ──
uv.lock

# ===========================
# Project-specific (below)
# ===========================
